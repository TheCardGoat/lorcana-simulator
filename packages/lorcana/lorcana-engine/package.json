{
  "name": "@tcg/lorcana-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Disney Lorcana TCG engine implementation using @tcg/core framework",
  "files": [
    "src/"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.d.ts",
  "imports": {
    "#core": "./src/core/index.ts",
    "#core/testing": "./src/core/testing/index.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "default": "./src/i18n/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    }
  },
  "scripts": {
    "build": "bun run i18n:compile && tsc --noEmit && mkdir -p dist",
    "typecheck": "bun run check-types",
    "check-types": "tsc --noEmit",
    "i18n:verify": "bun run i18n:compile && bun run i18n:check",
    "i18n:compile": "bun x @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/i18n/paraglide",
    "events:check": "bun run ./src/i18n/check-custom-event-usage.ts",
    "i18n:check": "bun run ./src/i18n/check-log-translations.ts && bun run ./src/i18n/check-custom-event-usage.ts",
    "audit:action-effect-coverage": "bun run ./scripts/audit-action-effect-resolver-coverage.ts",
    "format": "bun x oxfmt --write './src/**/*.ts'",
    "lint": "bun x oxlint --fix ./src",
    "test": "AGENT=1 bun test --silent --reporter=junit --reporter-outfile=./bun.xml",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "check": "turbo format lint check-types test"
  },
  "dependencies": {
    "@logtape/logtape": "^2.0.4",
    "@tcg/lorcana-types": "workspace:*",
    "immer": "11.0.1",
    "nanoid": "^5.0.0",
    "seedrandom": "^3.0.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.10.0",
    "@types/bun": "1.3.4",
    "@types/seedrandom": "^3.0.8",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  }
}
