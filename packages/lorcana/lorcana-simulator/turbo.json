{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "dependsOn": ["i18n:compile"],
      "cache": false,
      "persistent": true
    },
    "check-types": {
      "dependsOn": ["^build", "i18n:compile"]
    },
    "test": {
      "dependsOn": ["^build", "i18n:compile"]
    },
    "build": {
      "dependsOn": ["^build", "i18n:compile"],
      "outputs": ["build/**", ".svelte-kit/output/**"],
      "inputs": [
        "src/**",
        "static/**",
        "package.json",
        "tsconfig.json",
        "svelte.config.js",
        "vite.config.ts"
      ],
      "env": ["PLATFORM", "NODE_ENV"]
    },
    "build:node": {
      "dependsOn": ["^build", "i18n:compile"],
      "outputs": ["build/**", ".svelte-kit/output/**"],
      "inputs": [
        "src/**",
        "static/**",
        "package.json",
        "tsconfig.json",
        "svelte.config.js",
        "vite.config.ts"
      ],
      "env": ["PLATFORM", "NODE_ENV"]
    }
  },
  "tags": ["lorcana"]
}
