{
  "name": "@tcg/lorcana-simulator",
  "version": "0.0.1",
  "keywords": [
    "svelte"
  ],
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "dev:calm": "HOT_UPDATE_DELAY_MS=1200 vite dev",
    "build": "vite build && npm run prepack",
    "build:node": "PLATFORM=node vite build",
    "preview": "vite preview",
    "start": "node build",
    "format": "bun x oxfmt --no-error-on-unmatched-pattern --write 'src/**/*.{js,jsx,ts,tsx,json,jsonc,json5,css,scss,less,html,md,mdx,graphql,yml,yaml,toml}'",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "precheck-types": "bun run i18n:compile",
    "i18n:verify": "bun run i18n:compile && bun run i18n:check",
    "i18n:compile": "bun x @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide-generated",
    "i18n:check": "bun run ./scripts/check-i18n-catalog.ts && bun run ./scripts/check-paraglide-bridge.ts && bun run ./scripts/check-localized-copy.ts",
    "check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "bun run check-types",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:e2e": "playwright test",
    "test:rules": "AGENT=1 bun test --silent src/testing/rules",
    "test:unit": "svelte-kit sync && AGENT=1 bun test --silent src/lib",
    "test:strategy": "AGENT=1 bun test --silent src/testing/strategy",
    "test": "bun run test:rules && bun run test:unit && bun run test:strategy",
    "storybook": "HOT_UPDATE_DELAY_MS=1200 storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/svelte": "^0.3.2",
    "@formkit/auto-animate": "^0.9.0",
    "@iconify/svelte": "^5.0.2",
    "@logtape/logtape": "^2.0.4",
    "@logtape/pretty": "^2.0.4",
    "@tanstack/svelte-virtual": "^3.13.22",
    "@tcg/core": "workspace:*",
    "@tcg/lorcana-cards": "workspace:*",
    "@tcg/lorcana-engine": "workspace:*",
    "@tcg/lorcana-types": "workspace:*",
    "@unpic/svelte": "^1.0.0",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "prosekit": "^0.18.4",
    "shadcn-svelte": "^1.1.1",
    "svelte-json-tree": "^2.2.0",
    "svelte-sound": "^0.6.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@inlang/paraglide-js": "^2.10.0",
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.561.0",
    "@playwright/test": "^1.58.1",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-svelte-csf": "^5.0.11",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/sveltekit": "^10.2.17",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^22",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^29.0.0",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.58.2",
    "publint": "^0.3.17",
    "storybook": "^10.2.17",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "svelte-sonner": "^1.0.7",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
