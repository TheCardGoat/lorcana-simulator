{
  "name": "@tcg/lorcana-simulator",
  "version": "0.0.1",
  "keywords": [
    "svelte"
  ],
  "files": [
    "src/"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/lib/index.ts",
  "module": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "svelte": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "import": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:calm": "HOT_UPDATE_DELAY_MS=1200 vite",
    "build": "vite build && npm run prepack",
    "build:node": "PLATFORM=node vite build",
    "preview": "vite preview",
    "start": "node build/index.js",
    "format": "bun x oxfmt --no-error-on-unmatched-pattern --write 'src/**/*.{js,jsx,ts,tsx,json,jsonc,json5,css,scss,less,html,md,mdx,graphql,yml,yaml,toml}'",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "bun run i18n:compile && svelte-kit sync && svelte-package && publint",
    "i18n:verify": "bun run i18n:compile && bun run i18n:check",
    "i18n:compile": "bun x @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "i18n:check": "bun run ./scripts/check-i18n-catalog.ts && bun run ./scripts/check-localized-copy.ts && bun run ./scripts/check-translation-keys.ts",
    "check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "bun run check-types",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:e2e": "playwright test",
    "test:e2e:dev": "bunx tsx ./node_modules/.bin/playwright test",
    "test:e2e:ui": "bunx tsx ./node_modules/.bin/playwright test --ui",
    "test:rules": "AGENT=1 bun test --silent src/testing/rules",
    "test:unit": "svelte-kit sync && AGENT=1 bun test --silent src/lib",
    "test:strategy": "AGENT=1 bun test --silent src/testing/strategy",
    "test:strategy:quick": "RUN_STRATEGY_LAB=1 STRATEGY_PRESET=quick AGENT=1 bun test --silent src/testing/strategy",
    "test:strategy:candidate": "RUN_STRATEGY_LAB=1 STRATEGY_PRESET=candidate AGENT=1 bun test --silent src/testing/strategy",
    "test:strategy:promotion": "RUN_STRATEGY_LAB=1 STRATEGY_PRESET=promotion AGENT=1 bun test --silent src/testing/strategy",
    "test:strategy:lab": "RUN_STRATEGY_LAB=1 AGENT=1 bun test --silent src/testing/strategy",
    "test:strategy:benchmark": "RUN_STRATEGY_BENCHMARK=1 STRATEGY_GAME_COUNT=100 AGENT=1 bun test --silent src/testing/strategy",
    "test": "bun run test:rules && bun run test:unit",
    "storybook": "HOT_UPDATE_DELAY_MS=1200 storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/svelte": "^0.3.2",
    "@formkit/auto-animate": "^0.9.0",
    "@iconify/svelte": "^5.0.2",
    "@logtape/logtape": "^2.0.4",
    "@logtape/pretty": "^2.0.4",
    "@tanstack/svelte-hotkeys": "^0.5.1",
    "@tanstack/svelte-table": "^8.21.3",
    "@tanstack/svelte-virtual": "^3.13.22",
    "@tcg/lorcana-cards": "workspace:*",
    "@tcg/lorcana-engine": "workspace:*",
    "@tcg/lorcana-types": "workspace:*",
    "@tcg/shared": "workspace:*",
    "@unpic/svelte": "^1.0.0",
    "add": "^2.0.6",
    "better-auth": "^1.4.18",
    "bits-ui": "^2.16.3",
    "bun": "^1.3.11",
    "button-group": "^0.0.4",
    "howler": "^2.2.4",
    "immer": "^11.1.4",
    "install": "^0.13.0",
    "kbd": "^0.1.0",
    "prosekit": "^0.18.4",
    "svelte-confetti": "^2.3.2",
    "svelte-json-tree": "^2.2.0",
    "tsx": "^4.21.0",
    "x": "^0.1.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@inlang/paraglide-js": "^2.10.0",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^0.577.0",
    "@playwright/test": "^1.58.1",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-svelte-csf": "^5.0.11",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/sveltekit": "^10.2.17",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/howler": "^2.2.12",
    "@types/node": "^22",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "jsdom": "^29.0.0",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.58.2",
    "publint": "^0.3.17",
    "shadcn-svelte": "^1.2.2",
    "storybook": "^10.2.17",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
