{
  "name": "the-card-goat-online",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/core/*",
    "packages/lorcana/*",
    "packages/riftbound/*",
    "packages/gundam/*"
  ],
  "scripts": {
    "lint": "oxlint apps/*/src packages/*/src packages/*/*/src",
    "lint:fix": "oxlint --fix apps/*/src packages/*/src packages/*/*/src",
    "format": "oxfmt --check apps/*/src packages/*/src packages/*/*/src",
    "format:fix": "oxfmt apps/*/src packages/*/src packages/*/*/src",
    "quality": "bun run lint && bun run format",
    "quality:fix": "bun run lint:fix && bun run format:fix",
    "build": "turbo run build",
    "build:node": "turbo run build:node",
    "build:cloudflare": "turbo run build:cloudflare",
    "build:web:cloudflare": "turbo run build:cloudflare --filter=@tcg/web",
    "deploy:web": "turbo run deploy --filter=@tcg/web",
    "deploy:web:staging": "turbo run deploy:staging --filter=@tcg/web",
    "check": "turbo run check",
    "check-types": "turbo run check-types",
    "dev": "turbo run @tcg/web#dev @tcg/api#dev:general @tcg/api#dev:game",
    "test": "turbo run test",
    "ci-check": "bash ./scripts/ci-check.sh ci-check:verbose",
    "ci-check:verbose": "turbo run lint check-types test",
    "ci-check-full": "bash ./scripts/ci-check.sh ci-check-full:verbose",
    "ci-check-full:verbose": "turbo run lint check-types test build && turbo run i18n:verify",
    "preview": "turbo run preview",
    "deploy": "turbo run deploy",
    "cf-typegen": "turbo run cf-typegen",
    "boundaries": "turbo boundaries",
    "clean": "bunx rimraf '**/node_modules' '**/.svelte-kit' '**/.turbo' '**/dist' && bun install"
  },
  "dependencies": {
    "@logtape/logtape": "^2.0.4",
    "@logtape/pretty": "^2.0.4",
    "@unpic/svelte": "^1.0.1",
    "object-hash": "3.0.0",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@evilmartians/lefthook": "1.11.2",
    "@types/seedrandom": "^3.0.8",
    "bun-types": "^1.3.5",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "lefthook": "^2.1.0",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.43.0",
    "turbo": "^2.8.16",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@sinclair/typebox": "^0.34.0",
    "zod": "^4.3.5"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "volta": {
    "bun": "1.2.18",
    "node": "24.12.0"
  },
  "packageManager": "bun@1.3.0"
}
